# Track large binary files with Git LFS
# These are prebuilt tools from upstream j-hc that rarely change
bin/**/*.jar filter=lfs diff=lfs merge=lfs -text
bin/**/*.so filter=lfs diff=lfs merge=lfs -text
bin/**/tq-* filter=lfs diff=lfs merge=lfs -text
bin/**/htmlq-* filter=lfs diff=lfs merge=lfs -text
bin/**/aapt2-* filter=lfs diff=lfs merge=lfs -text
bin/**/detach filter=lfs diff=lfs merge=lfs -text
bin/**/ksu_profile filter=lfs diff=lfs merge=lfs -text
